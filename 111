"""
写一个简单的计算器程序，实现加减乘除
"""

#读取前两个数据
num1 = float(input("请输入第一个数据"))
num2 = float(input("请输入第二个数据"))

#读取运算符
op = input("请输入运算符(+ - * /)")

#计算机实现
if op == "+":
    print(num1 + num2)
if op == "-":
    print(num1 - num2)
if op == "*":
    print(num1 * num2)
if op == "/":
    # 防止除零报错
    if num2 == 0:
        print("错误:除数不能为0")
    else:
        print(num1 / num2)
else:
    print("运算符非法")

